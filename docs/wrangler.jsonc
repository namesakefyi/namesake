{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "docs",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-10-22",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "preview_urls": true
}
