{
  "name": "namesake",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter namesake-web dev",
    "dev:docs": "pnpm --filter namesake-docs dev",
    "dev:pdf": "pnpm --filter pdf-manager dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "check:fix": "pnpm -r check:fix",
    "test": "pnpm -r test"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{astro,cjs,css,js,json,jsonc,jsx,mjs,ts,tsx}": [
      "biome check --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1"
  }
}
