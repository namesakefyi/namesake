{
  "name": "namesake",
  "type": "module",
  "version": "0.0.1",
  "license": "GPL-3.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "astro dev --open",
    "start": "astro dev",
    "build": "pnpm pdf:schema && wrangler types && astro check && astro build",
    "build:only": "astro build",
    "preview": "wrangler types && astro preview",
    "astro": "astro",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "astro check && biome check",
    "check:fix": "astro check && biome check --write",
    "test": "vitest",
    "test:once": "vitest run",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --reporter=html",
    "check-links": "lychee --config .lychee.toml .",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "idb:add-migration": "node scripts/create-idb-migration.mjs",
    "pdf:schema": "tsx scripts/extract-pdf-schema.ts",
    "pdf:manage": "vite --config pdf-manager/vite.config.ts --open"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{astro,cjs,css,js,json,jsonc,jsx,mjs,ts,tsx}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "13.6.0",
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/react": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@axe-core/playwright": "^4.11.3",
    "@cantoo/pdf-lib": "^2.7.1",
    "@hono/node-server": "^2.0.4",
    "@internationalized/date": "^3.12.2",
    "@maskito/core": "^5.2.2",
    "@remixicon/react": "^4.9.0",
    "@severo_bo/us-atlas-2023": "^4.0.0",
    "@xstate/react": "^6.1.0",
    "astro": "6.4.2",
    "browserslist": "^4.28.2",
    "cf-workers-og": "^3.0.1",
    "d3": "^7.9.0",
    "d3-geo": "^3.1.1",
    "d3-selection": "^3.0.0",
    "fathom-client": "^3.7.2",
    "hono": "^4.12.23",
    "idb": "^8.0.3",
    "language-name-map": "^0.3.0",
    "react": "^19.2.7",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "react-lite-youtube-embed": "^3.5.1",
    "rough-notation": "^0.5.1",
    "sanitize-html": "^2.17.4",
    "topojson-client": "^3.1.0",
    "typescript": "^5.9.3",
    "ua-parser-js": "^2.0.10",
    "xstate": "^5.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@clack/prompts": "^1.5.0",
    "@playwright/test": "^1.60.0",
    "@react-aria/test-utils": "1.0.0-beta.3",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/addon-themes": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/builder-vite": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vueless/storybook-dark-mode": "^10.0.8",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.33",
    "clsx": "^2.1.1",
    "cssnano": "^8.0.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "nano-staged": "^1.0.2",
    "optimo": "^0.0.27",
    "pdfjs-dist": "^6.0.227",
    "react-compiler-runtime": "^1.0.0",
    "sass-embedded": "^1.100.0",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.1",
    "tsx": "^4.22.4",
    "vite": "^7.3.3",
    "vitest": "4.1.8",
    "wrangler": "^4.98.0"
  },
  "packageManager": "pnpm@11.1.2",
  "homepage": "https://namesake.fyi",
  "bugs": {
    "url": "https://github.com/namesakefyi/namesake/issues"
  },
  "contributors": [
