---
import type { SanityImageSource } from "@sanity/image-url";
import SanityImage from "./SanityImage.astro";

interface Props {
  title: string;
  date: string;
  url: string;
  subhead?: string;
  authors?: string[] | null;
  description?: string;
  image?: {
    asset?: SanityImageSource;
    alt?: string;
  } | null;
}

const { title, date, url, subhead, authors, description, image } = Astro.props;

const dateObj = new Date(date);
const formattedDate = new Intl.DateTimeFormat("en-US", {
  timeZone: "UTC",
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(dateObj);
---

<article class="article">
  <time class="date" datetime={dateObj.toISOString()}>
    {formattedDate}
  </time>
  {subhead && <strong class="subhead">{subhead}</strong>}
  <h2 class="title">
    <a href={url} class="title-text">{title}</a>
  </h2>
  {authors && <strong class="authors">By {authors.join(", ")}</strong>}
  {description && <p class="description">{description}</p>}
  {
    image?.asset && (
      <a class="image" href={url} tabindex="-1">
        <SanityImage
          asset={image.asset}
          alt={image.alt}
          options={{ width: 800, height: 450 }}
        />
      </a>
    )
  }
</article>

<style>
  .article {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: var(--space-2xs);
    break-inside: avoid;

    &:not(:last-child) {
      padding-block-end: var(--space-2xl);
    }
  }

  .title {
    font-size: var(--step-3);
    font-weight: var(--weight-bold);
    max-width: 36ch;
    text-wrap: balance;
    hyphens: auto;
    margin-block-end: var(--space-xs);
  }

  .title,
  .date,
  .subhead {
    z-index: 1;
  }

  .title,
  .title-text {
    line-height: var(--line-height-display);
  }

  .description {
    text-wrap: pretty;
    max-width: 48ch;
  }

  .image {
    order: -1;
    max-width: 600px;
    margin-block-end: var(--space-s);
    filter: grayscale(100%);
    mix-blend-mode: luminosity;
    transform: translate3d(0, 0, 0);

    // Safari bugfix

    img {
      border-radius: 3px;
    }
  }
</style>
