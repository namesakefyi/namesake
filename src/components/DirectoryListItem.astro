---
import {
  RiGlobalLine,
  RiMailSendLine,
  RiMapPinLine,
  RiPhoneLine,
  RiVerifiedBadgeFill,
} from "@remixicon/react";
import type { SanityAssetDocument } from "@sanity/client";
import { SERVICE_LABELS, type Service } from "@/constants/services";
import { formatCleanUrl } from "@/utils/formatCleanUrl";
import SanityImage from "./SanityImage.astro";

interface Props {
  name: string;
  description: string;
  state: string;
  services: Service[];
  email?: string;
  phone?: string;
  url: string;
  logo?: { asset: SanityAssetDocument };
  officialPartner?: boolean;
}

const {
  name,
  description,
  state,
  services,
  email,
  phone,
  url,
  logo,
  officialPartner,
} = Astro.props;

const contactLinks = [
  { icon: RiGlobalLine, href: url, label: formatCleanUrl(url) },
  { icon: RiMailSendLine, href: `mailto:${email}`, label: email },
  { icon: RiPhoneLine, href: `tel:${phone}`, label: phone },
].filter((link) => link.label);
---

<li class="directory-list-item">
  {
    logo?.asset && (
      <SanityImage
        className="directory-logo"
        options={{ height: 64 }}
        asset={logo.asset}
        alt={`${name} logo`}
      />
    )
  }
  <header>
    {
      officialPartner && (
        <div class="badge">
          <RiVerifiedBadgeFill />
          Namesake Partner
        </div>
      )
    }
    <h3>{name}</h3>
    <p class="description">{description}</p>
  </header>
  <ul class="services">
    {services.map((service) => <li>{SERVICE_LABELS[service] ?? service}</li>)}
  </ul>
  <ul class="contact-info">
    <li>
      <RiMapPinLine />
      {state}
    </li>
    {
      contactLinks.map(({ icon: Icon, href, label }) => (
        <li>
          <Icon />
          <a href={href}>{label}</a>
        </li>
      ))
    }
  </ul>
</li>

<style>
  .directory-list-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-s);
    break-inside: avoid;
    padding-block-end: var(--space-2xl);
  }

  :global(.directory-logo) {
    max-height: 64px;
    width: auto;
    filter: grayscale(100%);
    mix-blend-mode: multiply;
  }

  header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-xs);
  }

  h3 {
    font-size: var(--step-1);
    line-height: var(--line-height-display);
    text-wrap: balance;
  }

  .description {
    font-size: var(--step--1);
    text-wrap: pretty;
    max-width: 65ch;
  }

  .badge {
    background-color: var(--text-color);
    color: var(--background-color);
    font-size: var(--step--2);
    font-weight: var(--weight-bold);
    border-radius: var(--radius-l);
    padding: 0.15em 0.5em 0.15em 0.3em;
    display: inline-flex;
    align-items: center;
    gap: 0.2em;
    white-space: nowrap;

    svg {
      width: 1rem;
      height: 1rem;
    }
  }

  .services {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    list-style: none;
    padding: 0;
    margin: 0;

    li {
      font-size: var(--step--2);
      padding: 0.15em 0.5em;
      border: 1px solid var(--border-color);
      border-left-width: 3px;
      white-space: nowrap;
    }
  }

  .contact-info {
    list-style-type: none;
    padding: 0;
    margin: 0;
    font-size: var(--step--1);

    li {
      display: flex;
      align-items: center;
      gap: var(--space-2xs);

      svg {
        width: 1rem;
        height: 1rem;
      }

      a {
        text-decoration: none;
        color: var(--text-color);
        &:hover {
          text-decoration: underline;
          text-decoration-thickness: 2px;
          text-underline-offset: 0.1em;
        }
      }
    }
  }
</style>
