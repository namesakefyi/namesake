---
import type { CollectionEntry } from "astro:content";

interface Props {
  guides: CollectionEntry<"guides">[];
  title?: string;
  titleHref?: string;
}

const { guides, title, titleHref } = Astro.props;
---

<section class="guide-link-group">
  {title && <h2>{titleHref ? <a href={titleHref}>{title}</a> : title}</h2>}
  <ul>
    {
      guides.map((guide) => (
        <li>
          <a
            href={`/guides/${guide.id}`}
            class:list={[{ stub: !!guide.data.stub }]}
          >
            {guide.data.title}
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .guide-link-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  h2 {
    font-size: var(--step-2);
  }

  ul {
    padding: 0;
    display: flex;
    list-style-type: none;
    flex-direction: column;
    gap: var(--space-xs);
    font-size: var(--step-1);
  }

  a {
    display: inline-block;
    text-decoration: none;

    @media (hover: hover) {
      &:hover {
        text-decoration: underline;
      }
    }

    &.stub {
      color: var(--invalid-color);
      text-decoration-color: var(--invalid-color);
    }
  }
</style>
