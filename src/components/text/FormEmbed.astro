---
const { form } = Astro.props.node;

if (!form?.slug?.current) return;

const slug = form.slug.current;
const title = form.title ?? "Open form";
const formUrl = `/forms/${slug}`;
---

<div class="form-embed">
  <div class="form-embed-frame">
    <iframe
      src={formUrl}
      title={title}
      loading="lazy"
    ></iframe>
  </div>
  <div class="form-embed-footer">
    <a href={formUrl} class="form-embed-expand">
      Open full form
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
        <polyline points="15 3 21 3 21 9"></polyline>
        <line x1="10" y1="14" x2="21" y2="3"></line>
      </svg>
    </a>
  </div>
</div>

<style>
  .form-embed {
    border: 0.5px solid var(--border-color);
    margin-block: var(--space-l);
    overflow: hidden;
  }

  .form-embed-frame {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    background: var(--surface-color, #fff);
  }

  .form-embed-footer {
    border-top: 0.5px solid var(--border-color);
    padding: var(--space-xs) var(--space-m);
    display: flex;
    justify-content: flex-end;
  }

  .form-embed-expand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-size: var(--step--1);
    color: var(--text-color);
    text-decoration: none;

    &:hover {
      text-decoration: underline;
    }

    svg {
      width: 1em;
      height: 1em;
      flex-shrink: 0;
    }
  }
</style>
