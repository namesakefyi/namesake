---
import { sanityClient } from "sanity:client";
import { FormContainer } from "../../components/forms/FormContainer/FormContainer";
import type { FormSlug } from "../../constants/forms";
import { getFormPdfMetadata } from "../../forms/getFormPdfMetadata";
import { FORM_BY_SLUG_WITH_GUIDE_COSTS_QUERY } from "../../sanity/queries";

const { form: formNode } = Astro.props.node;

if (!formNode?.slug?.current) return;

const slug = formNode.slug.current as FormSlug;

const form = await sanityClient.fetch(FORM_BY_SLUG_WITH_GUIDE_COSTS_QUERY, {
  slug,
});

if (!form) return;

const pdfs = await getFormPdfMetadata(slug);
---

<div class="not-content form-embed">
  <FormContainer
    client:load
    slug={slug}
    title={form.title}
    description={form.description}
    banner={form.banner}
    updatedAt={form._updatedAt}
    pdfs={pdfs}
    costs={form.costs}
    inline
  />
</div>

<style>
  .form-embed {
    margin-block: var(--space-xl);
    border: 1px solid var(--border-color);
    padding-block-end: var(--space-xl);
    box-shadow:
      5px 5px 0 -3px var(--background-color),
      5px 5px 0 -2px var(--border-color),
      10px 10px 0 -5px var(--background-color),
      10px 10px 0 -4px var(--border-color);
  }
</style>
