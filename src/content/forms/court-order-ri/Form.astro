---
import { getEntry, render } from "astro:content";
import { FormContainer } from "../../../components/forms/FormContainer/FormContainer";
import { getFormPdfMetadata } from "../../../forms/getFormPdfMetadata";

const formEntry = await getEntry("forms", "court-order-ri");
if (!formEntry) return;
const { Content } = await render(formEntry);
const pdfs = await getFormPdfMetadata("court-order-ri");
---

<FormContainer
  client:load
  slug="court-order-ri"
  title={formEntry.data.title}
  description={formEntry.data.description}
  costs={formEntry.data.costs}
  pdfs={pdfs}
  inline
>
  <Content />
</FormContainer>
