---
import PageHeader from "@/components/PageHeader.astro";
import { DirectoryList } from "@/components/react/directory/DirectoryList";
import type { DirectoryContact } from "@/directory/directoryContact";
import { DIRECTORY_CONTACTS_LIST_GROQ } from "@/directory/directoryContactsQuery";
import { parseDirectorySearchParams } from "@/directory/parseDirectorySearchParams";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { loadQuery } from "@/sanity/lib/loadQuery";

export const prerender = false;

const { selectedStateSlug, selectedService } = parseDirectorySearchParams(
  Astro.url.searchParams,
);

const { data: filterStates } = await loadQuery<
  { name: string; slug: string }[]
>({
  query: `*[_type == "state" && defined(slug)] | order(name asc) {
    name,
    "slug": slug.current
  }`,
});

const { data: contacts } = await loadQuery<DirectoryContact[]>({
  query: DIRECTORY_CONTACTS_LIST_GROQ,
  params: {
    stateSlug: selectedStateSlug,
    service: selectedService,
  },
});

const title = "Directory";
const description =
  "Need more name change support? These organizations can help.";
---

<BaseLayout title={title} description={description} color="pink">
  <PageHeader title={title} description={description} />
  <DirectoryList
    client:load
    initialContacts={contacts}
    filterStates={filterStates}
    initialStateSlug={selectedStateSlug}
    initialService={selectedService}
  />
</BaseLayout>
