---
import {
  DirectoryList,
  parseDirectorySearchParams,
} from "../../components/directory/DirectoryList/DirectoryList";
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDirectoryContacts } from "../../utils/getDirectoryContacts";

const filters = parseDirectorySearchParams(Astro.url.searchParams);
const { contacts, allStates } = await getDirectoryContacts(filters);

const title = "Directory";
const description =
  "Need more name change support? These organizations can help.";
---

<BaseLayout title={title} description={description} color="pink">
  <PageHeader title={title} description={description} />
  <DirectoryList
    client:load
    initialContacts={contacts}
    initialUrlSearch={Astro.url.search}
    allStates={allStates}
  />
</BaseLayout>
