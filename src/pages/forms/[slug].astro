---
export const prerender = true;

import { type CollectionEntry, getCollection } from "astro:content";
import { FormContainer } from "../../components/forms/FormContainer/FormContainer";
import type { FormSlug } from "../../constants/forms";
import { getFormConfig } from "../../forms/getFormConfig";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const forms = await getCollection("forms");
  return forms.map((form) => ({ params: { slug: form.id }, props: { form } }));
}

interface Props {
  form: CollectionEntry<"forms">;
}

const { form } = Astro.props;
const { slug } = Astro.params;
const config = getFormConfig(form.id);
if (!config) return Astro.redirect("/404");
---

<BaseLayout
  title={config.title}
  description={config.description}
  color="white"
  ogImage={`/forms/${slug}.png`}
>
  <FormContainer client:load slug={form.id as FormSlug} />
</BaseLayout>
