---
export const prerender = true;

import { type CollectionEntry, getCollection, render } from "astro:content";
import { FormContainer } from "../../components/forms/FormContainer/FormContainer";
import { isFormSlug } from "../../constants/forms";
import { getFormPdfMetadata } from "../../forms/getFormPdfMetadata";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const forms = await getCollection("forms");
  return forms
    .filter((form) => isFormSlug(form.id))
    .map((form) => ({ params: { slug: form.id }, props: { form } }));
}

interface Props {
  form: CollectionEntry<"forms">;
}

const { form } = Astro.props;
const { slug } = Astro.params;

if (!isFormSlug(form.id)) return Astro.redirect("/404");

const { Content } = await render(form);
const pdfs = await getFormPdfMetadata(form.id);
---

<BaseLayout
  title={form.data.title}
  description={form.data.description}
  color="white"
  ogImage={`/forms/${slug}.png`}
>
  <FormContainer
    client:load
    slug={form.id}
    title={form.data.title}
    description={form.data.description}
    costs={form.data.costs}
    pdfs={pdfs}
  >
    <Content />
  </FormContainer>
</BaseLayout>
