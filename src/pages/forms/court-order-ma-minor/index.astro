---
import { sanityClient } from "sanity:client";
import { FormContainer } from "../../../components/forms/FormContainer/FormContainer";
import type { FormSlug } from "../../../constants/forms";
import { getFormPdfMetadata } from "../../../forms/getFormPdfMetadata";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { FORM_BY_SLUG_WITH_GUIDE_COSTS_QUERY } from "../../../sanity/queries";

const formSlug: FormSlug = "court-order-ma-minor";

const form = await sanityClient.fetch(FORM_BY_SLUG_WITH_GUIDE_COSTS_QUERY, {
  slug: formSlug,
});

if (!form) return Astro.redirect("/404");

const pdfs = await getFormPdfMetadata(formSlug);
---

<BaseLayout title={form.title} description={form.description} color="white">
  <FormContainer
    client:load
    slug={formSlug}
    title={form.title}
    description={form.description}
    banner={form?.banner}
    updatedAt={form?._updatedAt}
    pdfs={pdfs}
    costs={form?.costs}
  />
</BaseLayout>
