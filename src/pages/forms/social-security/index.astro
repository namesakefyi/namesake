---
import { sanityClient } from "sanity:client";
import { FormContainer } from "@/components/react/forms/FormContainer/FormContainer";
import type { FormSlug } from "@/constants/forms";
import { getFormPdfMetadata } from "@/forms/getFormPdfMetadata";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { FORM_BY_SLUG_QUERY } from "@/sanity/queries";

const formSlug: FormSlug = "social-security";

const form = await sanityClient.fetch(FORM_BY_SLUG_QUERY, {
  slug: formSlug,
});

if (!form) return Astro.redirect("/404");

const pdfs = await getFormPdfMetadata(formSlug);
---

<BaseLayout title={form.title} description={form.description} color="white">
  <FormContainer
    client:load
    slug={formSlug}
    title={form.title}
    description={form.description}
    updatedAt={form._updatedAt}
    pdfs={pdfs}
  />
</BaseLayout>
