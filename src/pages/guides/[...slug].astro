---
import { getCollection, getEntry, render } from "astro:content";
import type { BreadcrumbItem } from "#components/Breadcrumbs.astro";
import GuideFooter from "#components/GuideFooter.astro";
import StubBanner from "#components/StubBanner.astro";
import TableOfContents from "#components/TableOfContents.astro";
import ProseLayout from "#layouts/ProseLayout.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides", ({ data }) => !data.unlisted);
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(guide);
const state = guide.data.state ? await getEntry(guide.data.state) : null;
---

<ProseLayout
  title={guide.data.title}
  description={guide.data.description}
  annotation="box"
  breadcrumbs={[
    { label: "Namesake", href: "/" },
    { label: "Guides", href: "/guides" },
    ...(state ? [{ label: state.data.name, href: `/guides/${state.id}` }] : []),
  ] satisfies BreadcrumbItem[]}
  color="white"
  ogImage={`/guides/${guide.id}.png`}
  ogAlt={guide.data.title}
>
  <TableOfContents headings={headings} slot="toc" />

  {guide.data.stub && <StubBanner />}
  <Content />
  <GuideFooter
    filePath={guide.filePath}
    lastModified={remarkPluginFrontmatter.lastModified}
  />
</ProseLayout>
