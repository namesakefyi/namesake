---
import { sanityClient } from "sanity:client";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import PageHeader from "@/components/PageHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { GUIDES_INDEX_QUERY } from "@/sanity/queries";
import { GuidesTable } from "./_components/GuidesTable";

dayjs.extend(utc);

const { params } = Astro.props;

const guides = await sanityClient.fetch(GUIDES_INDEX_QUERY, params ?? {});
---

<BaseLayout
  title="Guides"
  description="Step-by-step name change guides for identity documents."
  color="white"
>
  <PageHeader
    title="Guides"
    description="Step-by-step name change guides for identity documents."
  />
  <div class="guides">
    <GuidesTable client:load guides={guides} />
  </div>
</BaseLayout>

<style>
  .guides {
    padding-block-end: var(--space-2xl);
  }
</style>
