---
import { getCollection, getEntry } from "astro:content";
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { GuidesTable } from "./_components/GuidesTable";

const allGuides = await getCollection("guides", ({ data }) => !data.unlisted);

const guides = await Promise.all(
  allGuides.map(async (guide) => {
    const stateEntry = guide.data.state
      ? await getEntry(guide.data.state)
      : null;
    const categoryEntry = guide.data.category
      ? await getEntry(guide.data.category)
      : null;

    return {
      id: guide.id,
      title: guide.data.title,
      state: stateEntry?.data.name ?? null,
      category: categoryEntry?.data.name ?? null,
    };
  }),
);
---

<BaseLayout
  title="Guides"
  description="Step-by-step name change guides for identity documents."
  color="white"
>
  <PageHeader
    title="Guides"
    description="Step-by-step name change guides for identity documents."
  />
  <div class="guides">
    <GuidesTable client:load guides={guides} />
  </div>
</BaseLayout>

<style>
  .guides {
    padding-block-end: var(--space-2xl);
  }
</style>
