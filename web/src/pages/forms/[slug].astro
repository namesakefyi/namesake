---
import { type CollectionEntry, getCollection } from "astro:content";
import type { FormSlug } from "#constants/forms";
import BaseLayout from "#layouts/BaseLayout.astro";
import { FormContainer } from "../../components/forms/FormContainer";
import { getFormConfig } from "../../lib/forms/getFormConfig";

export async function getStaticPaths() {
  const forms = await getCollection("forms");
  return forms.map((form) => ({ params: { slug: form.id }, props: { form } }));
}

interface Props {
  form: CollectionEntry<"forms">;
}

const { form } = Astro.props;
const { slug } = Astro.params;
const config = getFormConfig(form.id);
if (!config) return Astro.redirect("/404");
---

<BaseLayout
  title={config.title}
  description={config.description}
  color="white"
  previewImage={{
    src: `/forms/${slug}.png`,
    alt: config.title,
  }}
>
  <FormContainer client:load slug={form.id as FormSlug} />
</BaseLayout>
