---
import type { BreadcrumbItem } from "#components/Breadcrumbs.astro";
import GuideLinkGroup from "#components/GuideLinkGroup.astro";
import PageHeader from "#components/PageHeader.astro";
import BaseLayout from "#layouts/BaseLayout.astro";
import { getGuidesByJurisdiction } from "#lib/queries/guides";

export async function getStaticPaths() {
  const { guidesByJurisdiction } = await getGuidesByJurisdiction();
  return guidesByJurisdiction.map(({ jurisdiction, guides }) => ({
    params: { jurisdiction: jurisdiction.id },
    props: { jurisdiction, guides },
  }));
}

const { jurisdiction, guides } = Astro.props;
---

<BaseLayout
  title={jurisdiction.data.name}
  description={`Step-by-step name change guides for ${jurisdiction.data.name}.`}
  color="white"
>
  <PageHeader
    title={jurisdiction.data.name}
    description={`Step-by-step name change guides for ${jurisdiction.data.name}.`}
    breadcrumbs={[
      { label: "Namesake", href: "/" },
      { label: "Guides", href: "/guides" },
    ] satisfies BreadcrumbItem[]}
  />
  <div class="guides">
    <GuideLinkGroup guides={guides} />
  </div>
</BaseLayout>

<style>
  .guides {
    padding-block-end: var(--space-2xl);
  }
</style>
